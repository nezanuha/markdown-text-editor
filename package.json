{
  "name": "markdown-text-editor",
  "version": "1.5.2",
  "type": "module",
  "description": "Lightweight Markdown editor with hybrid WYSIWYG mode, real-time preview, and zero-config setup. Works with any backend via native textarea.",
  "funding": "https://ko-fi.com/nezanuha",
  "main": "./dist/markdown-text-editor.umd.js",
  "module": "./dist/markdown-text-editor.es.js",
  "browser": "./dist/markdown-text-editor.min.js",
  "unpkg": "./dist/markdown-text-editor.min.js",
  "jsdelivr": "./dist/markdown-text-editor.min.js",
  "exports": {
    ".": {
      "import": "./dist/markdown-text-editor.es.js",
      "require": "./dist/markdown-text-editor.umd.js",
      "default": "./dist/markdown-text-editor.umd.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nezanuha/markdown-text-editor.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "postversion": "git push origin main --tags"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "keywords": [
    "markdown",
    "markdown editor",
    "wysiwyg",
    "wysiwyg markdown",
    "textarea markdown editor",
    "embeddable markdown editor",
    "markdown preview",
    "rich text editor",
    "text editor",
    "markdown plugin",
    "rtl",
    "rtl markdown",
    "dark mode",
    "find and replace",
    "django markdown",
    "laravel markdown",
    "csp compatible",
    "form markdown editor",
    "live preview",
    "mde"
  ],
  "author": "Nezanuha",
  "license": "MIT",
  "homepage": "https://frutjam.com/plugins/markdown-editor",
  "bugs": {
    "url": "https://github.com/nezanuha/markdown-text-editor/issues"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "marked": "~18.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "diff": "^9.0.0",
    "frutjam": "^2.2.5",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.5",
    "vite-plugin-css-injected-by-js": "^5.0.2"
  }
}
