{
  "name": "markdown-text-editor",
  "version": "1.4.0",
  "type": "module",
  "description": "Lightweight Markdown editor with hybrid WYSIWYG mode, real-time preview, and zero-config setup. Works with any backend via native textarea.",
  "funding": "https://ko-fi.com/nezanuha",
  "main": "./dist/markdown-text-editor.umd.js",
  "module": "./dist/markdown-text-editor.es.js",
  "browser": "./dist/markdown-text-editor.min.js",
  "unpkg": "./dist/markdown-text-editor.min.js",
  "jsdelivr": "./dist/markdown-text-editor.min.js",
  "exports": {
    ".": {
      "import": "./dist/markdown-text-editor.es.js",
      "require": "./dist/markdown-text-editor.umd.js",
      "default": "./dist/markdown-text-editor.umd.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nezanuha/markdown-text-editor.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "postversion": "git push origin main --tags"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "keywords": [
    "markdown",
    "mde",
    "markdown js library",
    "markdown js plugin",
    "editor",
    "markdown editor",
    "Simple Markdown editor js plugin",
    "text editor",
    "markdown preview",
    "markdown syntax",
    "markdown plugin",
    "rich text editor",
    "wysiwyg",
    "markdown formatting",
    "tailwindcss",
    "code editor",
    "editor plugin",
    "text formatting",
    "markdown-text-editor",
    "Tailwind css markdown editor",
    "Tailwind css markdown",
    "WYSIWYG-style markdown editor",
    "Simple Markdown",
    "Responsive markdown js editor",
    "RTL Support markdown editor"
  ],
  "author": "Nezanuha",
  "license": "MIT",
  "homepage": "https://frutjam.com/plugins/markdown-editor",
  "bugs": {
    "url": "https://github.com/nezanuha/markdown-text-editor/issues"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "marked": "~18.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "diff": "^9.0.0",
    "frutjam": "^2.2.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0",
    "vite-plugin-css-injected-by-js": "^5.0.1"
  }
}
